{
  "permissions": {
    "allow": [
      "Bash(bash:*)",
      "Bash(grep:*)",
      "Bash(find:*)",
      "Bash(cat:*)",
      "Bash(ls:*)",
      "Bash(mkdir:*)",
      "Bash(go:*)",
      "Bash(python3:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git branch:*)",
      "Bash(git stash:*)",
      "Bash(git checkout:*)"
    ],
    "deny": [
      "Bash(git push:*)",
      "Bash(curl:*)",
      "Bash(wget:*)"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "V=${VAULT_PATH:-$(pwd)}; [ -f \"$V/.claude/tools/vault-tools\" ] && \"$V/.claude/tools/vault-tools\" session-start 2>/dev/null; exit 0",
            "shell": "bash"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Bash",
        "hooks": [
          {
            "type": "command",
            "command": "V=${VAULT_PATH:-$(pwd)}; [ -f \"$V/.claude/tools/vault-tools\" ] && \"$V/.claude/tools/vault-tools\" update-inbox-count 2>/dev/null; exit 0",
            "shell": "bash",
            "async": true
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "V=${VAULT_PATH:-$(pwd)}; [ -f \"$V/.claude/tools/vault-tools\" ] && \"$V/.claude/tools/vault-tools\" session-end 2>/dev/null; exit 0",
            "shell": "bash",
            "async": true
          }
        ]
      }
    ]
  }
}
